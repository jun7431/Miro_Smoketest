# Required production storage mode
MIRO_STORAGE_DRIVER=supabase

# Required Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional table/schema overrides
# MIRO_SUPABASE_SCHEMA=public
# MIRO_SUPABASE_EVENTS_TABLE=tracking_events
# MIRO_SUPABASE_SIGNUPS_TABLE=signup_submissions

# Optional protected debug endpoint token for /api/debug
MIRO_ADMIN_TOKEN=replace-this-with-a-long-random-string
